#!/bin/sh
# usage-check — print Claude subscription usage on one line:
#   <five_hr%> <seven_day%> <five_hr_reset_iso> <seven_day_reset_iso>
# Reads the Claude Code OAuth token from the macOS Keychain at runtime;
# never stores it. Fields print "?" when the API omits them.
set -eu
TOKEN=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null \
  | /usr/bin/python3 -c 'import sys,json;print(json.load(sys.stdin)["claudeAiOauth"]["accessToken"])')
curl -sf --max-time 15 https://api.anthropic.com/api/oauth/usage \
  -H "Authorization: Bearer $TOKEN" \
  -H "anthropic-beta: oauth-2025-04-20" \
  | /usr/bin/python3 -c '
import sys, json
d = json.load(sys.stdin)
def pct(w):
    if not w: return "?"
    u = w.get("utilization")
    return str(round(u)) if u is not None else "?"
def reset(w):
    if not w: return "?"
    return w.get("resets_at") or "?"
five = d.get("five_hour") or {}
seven = d.get("seven_day") or {}
print(pct(five), pct(seven), reset(five), reset(seven))
'
